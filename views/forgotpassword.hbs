<div class="forgot-password-page">
    <div class="forgot-password-shell">
        <div class="forgot-password-card">
            <div class="forgot-password-left">
                <img class="forgot-password-logo" src="/images/logo2.png" alt="CoFeed Logo"/>

                <div class="forgot-password-copy">
                    <p class="forgot-eyebrow">Account Recovery</p>
                    <h1 class="forgot-greeting">Welcome back,<br>Brew Buddy!</h1>
                    <p class="forgot-tagline">Ready to Sip, Share, and</p>
                    <p class="forgot-tagline">Discover the Perfect Pour?</p>
                </div>
            </div>

            <div class="forgot-password-divider"></div>

            <div class="forgot-password-right">
                <p class="forgot-main">Change Password</p>
                <p class="forgot-subtext">Update your password securely and regain access to your account.</p>
            {{#if isLoggedIn}}

            <!-- CHANGE PASSWORD (LOGGED IN) -->
            <form onsubmit="return submitChangePasswordForm()">

                <div class="forgot-form-group">
                    <label>Current Password</label>
                    <input id="current-password" type="password">
                </div>

                <div class="forgot-form-group">
                    <label>New Password</label>
                    <input id="logged-in-new-password" type="password">
                </div>

                <input type="submit" class="forgot-password-button" value="Change Password">
            </form>

            <hr style="border: 0; border-top: 1px solid rgba(82, 61, 53, 0.15); margin: 1.5rem 0;">

            <p class="forgot-main" style="font-size: 1.1rem;">Password recovery phrase</p>
            <p class="forgot-subtext">Set your own question and a long random answer (8+ characters each). If you save this, forgot-password will ask for your answer instead of an OTP. Requires your current password.</p>
            <form onsubmit="return submitSetRecoveryForm()">
                <div class="forgot-form-group">
                    <label for="recovery-current-pw">Current password</label>
                    <input id="recovery-current-pw" type="password" placeholder="Required to save" autocomplete="off">
                </div>
                <div class="forgot-form-group">
                    <label for="recovery-q-setup">Recovery question</label>
                    <input id="recovery-q-setup" type="text" placeholder="At least 8 characters">
                </div>
                <div class="forgot-form-group">
                    <label for="recovery-a-setup">Recovery answer</label>
                    <input id="recovery-a-setup" type="password" placeholder="Random phrase, 8+ characters" autocomplete="off">
                </div>
                <input type="submit" class="forgot-password-button" value="Save recovery settings">
            </form>

            {{else}}

            <!-- FORGOT PASSWORD (NOT LOGGED IN) -->
            <form onsubmit="return submitForgotPasswordForm()">

                <div class="forgot-form-group">
                    <div class="forgot-form-group">
                        <label>Email</label>
                        <input id="email-field" type="email" placeholder="Enter your email">
                    </div>

                    <button type="button" onclick="sendOTP()" class="forgot-password-button">
                        Continue
                    </button>

                    <div id="otp-block" class="forgot-form-group">
                        <label>OTP</label>
                        <input id="otp-field" type="text" placeholder="Enter OTP">
                    </div>

                    <div id="recovery-block" class="forgot-form-group" style="display: none;">
                        <label>Your recovery question</label>
                        <p id="recovery-question-text" class="forgot-subtext" style="margin-bottom: 0.5rem;"></p>
                        <label for="recovery-answer-field">Answer</label>
                        <input id="recovery-answer-field" type="password" placeholder="Your recovery answer" autocomplete="off">
                    </div>

                    <div class="forgot-form-group">
                        <label>New Password</label>
                        <input id="new-password" type="password" placeholder="New Password">
                    </div>

                    <input type="submit" class="forgot-password-button" value="Reset Password">
            </form>

            {{/if}}
            </div>
        </div>
    </div>
</div>