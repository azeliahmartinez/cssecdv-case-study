<!-- Create Establishment Widget -->
<div id="create-establishment-widget" class="edit-widget-container create-establishment-modal">
    <div class="modal-header">
        <div>
            <p class="modal-eyebrow">New Listing</p>
            <h2 class="modal-title">Create Establishment</h2>
        </div>
        <button class="close-button" type="button" onclick="hideEstablishmentWidget()">×</button>
    </div>

    <form id="create-establishment-form" name="create-establishment" onsubmit="return createEstablishment()">
        <div class="info-item">
            <label for="establishment-name">Establishment Name</label>
            <input type="text" id="establishment-name-field" name="establishment_name" placeholder="e.g. Kape Benito" required>
        </div>

        <div class="info-item">
            <label for="establishment-address">Establishment Address</label>
            <input type="text" id="establishment-address-field" name="establishment_address" placeholder="e.g. 48 Sparrow St., Marikina City" required>
        </div>

        <div class="info-item">
            <label for="establishment-description">Establishment Description</label>
            <input type="text" id="establishment-description-field" name="establishment_description" placeholder="Short description of the cafe" required>
        </div>

        <div class="info-item">
            <label for="price-range">Price Range</label>
            <input type="text" id="price-range-field" name="price_range" placeholder="e.g. ₱150 - ₱250" required>
        </div>

        <div class="info-item">
            <label for="banner-image">Banner Image URL</label>
            <input type="text" id="banner-image-field" name="banner_image" placeholder="https://example.com/banner.jpg">
        </div>

        <div class="info-item">
            <label for="services-offered">Services Offered</label>
            <input type="text" id="services-offered-field" name="services_offered" placeholder="e.g. Dine-in, Take Out, Wi-Fi">
        </div>

        <div class="info-item">
            <label for="establishment-schedule">Establishment Schedule</label>
            <input type="text" id="establishment-schedule-field" name="establishment_schedule" placeholder="e.g. 9:00 AM - 10:00 PM, 9:00 AM - 10:00 PM, ...">
        </div>

        <div class="info-item">
            <label for="contact-details-fb">Facebook</label>
            <input type="text" id="contact-details-fb-field" name="contact_details_FB" placeholder="e.g. Kape Benito Community Cafe">
        </div>

        <div class="info-item">
            <label for="contact-details-ig">Instagram</label>
            <input type="text" id="contact-details-ig-field" name="contact_details_IG" placeholder="e.g. @kapebenito.cafe">
        </div>

        <div class="info-item">
            <label for="establishment-images">Additional Image URLs</label>
            <input type="text" id="establishment-images-field" name="establishment_images" placeholder="https://example.com/1.jpg, https://example.com/2.jpg">
        </div>

        <div class="info-item">
            <label for="establishment-map">Google Maps Embed URL</label>
            <input type="text" id="establishment-map-field" name="establishment_map" placeholder="https://www.google.com/maps/embed?...">
        </div>

        <input id="create-establishment-button" type="submit" class="establishment-submit" value="Create Establishment">
    </form>
</div>