<!-- Create Establishment Widget -->
<div id="create-establishment-widget" class="edit-widget-container create-establishment-modal">
    <div class="modal-header">
        <div>
            <p class="modal-eyebrow">New Listing</p>
            <h2 class="modal-title">Create Establishment</h2>
        </div>
        <button class="close-button" type="button" onclick="hideEstablishmentWidget()">×</button>
    </div>

    <form id="create-establishment-form" name="create-establishment" onsubmit="return createEstablishment()">
        <div class="info-item">
            <label for="establishment-name">Establishment Name</label>
            <input type="text" id="establishment-name-field" name="establishment_name" placeholder="Enter establishment name">
        </div>
        <div class="info-item">
            <label for="establishment-address">Establishment Address</label>
            <input type="text" id="establishment-address-field" name="establishment_address" placeholder="Enter establishment address">
        </div>
        <div class="info-item">
            <label for="establishment-description">Establishment Description</label>
            <input type="text" id="establishment-description-field" name="establishment_description" placeholder="Enter establishment description">
        </div>
        <div class="info-item">
            <label for="price-range">Price Range</label>
            <input type="text" id="price-range-field" name="price_range" placeholder="Enter price range">
        </div>
        <div class="info-item">
            <label for="banner-image">Banner Image URL</label>
            <input type="text" id="banner-image-field" name="banner_image" placeholder="Enter banner image URL">
        </div>
        <div class="info-item">
            <label for="establishment-ratings">Establishment Ratings</label>
            <input type="number" id="establishment-ratings-field" name="establishment_ratings" placeholder="Enter establishment ratings">
        </div>
        <div class="info-item">
            <label for="services-offered">Services Offered (comma-separated)</label>
            <input type="text" id="services-offered-field" name="services_offered" placeholder="Enter services offered">
        </div>
        <div class="info-item">
            <label for="establishment-schedule">Establishment Schedule (comma-separated)</label>
            <input type="text" id="establishment-schedule-field" name="establishment_schedule" placeholder="Enter establishment schedule">
        </div>
        <div class="info-item">
            <label for="contact-details-fb">Contact Details (Facebook)</label>
            <input type="text" id="contact-details-fb-field" name="contact_details_FB" placeholder="Enter Facebook contact details">
        </div>
        <div class="info-item">
            <label for="contact-details-ig">Contact Details (Instagram)</label>
            <input type="text" id="contact-details-ig-field" name="contact_details_IG" placeholder="Enter Instagram contact details">
        </div>
        <div class="info-item">
            <label for="establishment-images">Establishment Images (comma-separated)</label>
            <input type="text" id="establishment-images-field" name="establishment_images" placeholder="Enter establishment images">
        </div>
        <div class="info-item">
            <label for="establishment-map">Establishment Map URL</label>
            <input type="text" id="establishment-map-field" name="establishment_map" placeholder="Enter establishment map URL">
        </div>
        <input id="create-establishment-button" type="submit" class="establishment-submit"value="Create Establishment"></input>
</form>
</div>
