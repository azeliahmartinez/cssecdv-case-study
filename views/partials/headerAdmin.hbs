<div class="header-item">
    <header>
        <div class="header-container">
            <div class="header-left">
                <div class="header-logo">
                    <a href="/admin/dashboard"><img id="logo" src="/images/logo.png" alt="CoFeed Logo"/></a>
                </div>

                <form action="/search" method="GET">
                    <div class="header-search">
                        <input class="search-bar" type="text" name="key" placeholder="Coffee shop, study area, etc...">
                        <button class="search-button" type="submit"><i class="fa fa-search"></i></button>
                    </div>
                </form>
            </div>

            <div class="header-right">
                <div class="header-button-home">
                    <a class="header-text" href="/landingPage">Home</a>
                </div>

                <div class="header-button-view-establishments">
                    <a class="header-text" href="/viewEstablishments">View Establishments</a>
                </div>

                <div class="header-button-owner-dashboard">
                    <a class="header-text" href="/admin/dashboard">Admin Dashboard</a>
                </div>

                <div class="header-button-owner-dashboard">
                    <a class="header-text" href="/owner/establishments">Manage Establishments</a>
                </div>

                <div class="header-profile">
                    <div class="avatar-button" onclick="toggleOptions(event)">
                        <div class="box-item">
                            <span class="header-text">{{currentUser}}</span>
                            <img src="{{currentUserIcon}}" alt="admin icon">
                        </div>
                        <i class="fa fa-chevron-down"></i>
                    </div>
                    <div class="avatar-dropdown-content" id="myDropdown">
                        <button onclick="window.location.href='/admin/dashboard'">Admin Dashboard</button>
                        <button onclick="window.location.href='/forgotpassword'">Change Password</button>
                        <button onclick="logout()">Logout</button>
                    </div>
                </div>
            </div>
        </div>
    </header>
</div>