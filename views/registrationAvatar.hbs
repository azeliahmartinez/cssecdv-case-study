<div class="register-page">
  <div class="register-shell">
    <div class="register-card">

      <div class="register-left">
        <img class="register-logo" src="/images/logo2.png" alt="CoFeed Logo">

        <p class="register-eyebrow">Create Account</p>
        <h1 class="register-greeting">Welcome,<br>Brew Buddy!</h1>
        <p class="register-tagline">Ready to Sip, Share, and</p>
        <p class="register-tagline">Discover the Perfect Pour?</p>
      </div>

      <div class="register-divider"></div>

      <div class="register-right" id="avatar-container">
        <h2 class="register-main">Choose Your Avatar</h2>
        <p class="register-subtext">Pick the avatar you want to use for your account.</p>

        <form class="avatar-form-modern" id="avatarForm">
          <div class="avatar-grid">
            {{#each user_icon}}
              <label class="avatar-option">
                <input type="radio" name="user_icon" value="{{user_icon}}" required>
                <img src="{{user_icon}}" alt="Avatar">
              </label>
            {{/each}}
          </div>

          <button type="submit" class="register-button">Choose Avatar</button>
        </form>
      </div>

    </div>
  </div>
</div>