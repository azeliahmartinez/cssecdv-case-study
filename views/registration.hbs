<div class="register-page">
    <div class="register-shell">
        <div class="register-card">
            <div class="register-left">
                <img class="register-logo" src="/images/logo2.png" alt="CoFeed Logo"/>

                <div class="register-copy">
                    <p class="register-eyebrow">Create Account</p>
                    <h1 class="register-greeting">Welcome,<br>Brew Buddy!</h1>
                    <p class="register-tagline">Ready to Sip, Share, and</p>
                    <p class="register-tagline">Discover the Perfect Pour?</p>
                </div>
            </div>

            <div class="register-divider"></div>

            <div class="register-right">
                <p class="register-main">Create Account</p>
                <p class="register-subtext">Create your account and start discovering cafés, reviews, and study spaces.</p>

                <form name="create-user" onsubmit="return submitForm()">
                    <div class="register-form-group">
                        <label for="register-name">Name</label>
                        <input id="register-name" name="name" type="text" placeholder="Enter your full name">
                    </div>

                    <div class="register-form-group">
                        <label for="username-field">Username</label>
                        <input id="username-field" name="username" type="text" placeholder="Choose a username">
                    </div>

                    <div class="register-form-group">
                        <label for="register-bio">Bio <span class="register-optional">(optional)</span></label>
                        <input id="register-bio" name="bio" type="text" placeholder="Tell us a little about you">
                    </div>

                    <div class="register-form-group">
                        <label for="register-email">Email</label>
                        <input id="register-email" name="email" type="text" placeholder="Enter your email">
                    </div>

                    <div class="register-form-group register-password-field-wrap">
                        <label for="password-field">Password</label>
                        <div class="register-password-input-wrap">
                            <input id="password-field" name="password" type="password" placeholder="Create a password">
                            <i
                                id="toggle-password"
                                class="fa fa-eye-slash register-password-toggle"
                                onclick="togglePasswordVisibility('password-field', 'toggle-password')"
                            ></i>
                        </div>
                    </div>

                    <div class="register-form-group register-password-field-wrap">
                        <label for="confirm-password-field">Confirm Password</label>
                        <div class="register-password-input-wrap">
                            <input id="confirm-password-field" name="password2" type="password" placeholder="Confirm your password">
                            <i
                                id="toggle-confirm-password"
                                class="fa fa-eye-slash register-password-toggle"
                                onclick="togglePasswordVisibility('confirm-password-field', 'toggle-confirm-password')"
                            ></i>
                        </div>
                    </div>

                    <input type="submit" class="register-button" value="Sign Up">
                </form>

                <p class="register-login-link">
                    <a href="/login">Already have an account? Login Here</a>
                </p>
            </div>
        </div>
    </div>
</div>