<!-- container for the header -->
<div class="parent-header">
    {{#if currentUser}}
        {{#if (eq currentUserType "admin")}}
            {{> headerAdmin}}
        {{else if (eq currentUserType "owner")}}
            {{> headerOwner}}
        {{else if (eq currentUserType "rater")}}
            {{> headerUser}}
        {{else}}
            {{> headerNonUser}}
        {{/if}}
    {{else}}
        {{> headerNonUser}}
    {{/if}}
</div>

<div class="landing-modern-page">

    <section class="landing-modern-hero">
        <div class="landing-modern-hero-overlay"></div>
        <div class="landing-modern-hero-content">
            <div class="landing-modern-hero-card">
                <p class="landing-modern-eyebrow">Welcome back</p>
                <h1 class="landing-modern-title">Hey, {{currentUserName}}.</h1>
                <p class="landing-modern-subtext">
                    See what your brew buddies have been sharing and explore highly rated cafés around you.
                </p>
            </div>
        </div>
    </section>

    <section class="landing-modern-section">
        <div class="landing-modern-section-head">
            <div>
                <p class="landing-modern-section-eyebrow">New from friends</p>
                <h2 class="landing-modern-section-title">Recent friend activity</h2>
            </div>
        </div>

        {{#if noRecentReviewsFromFriends}}
            <div class="landing-modern-empty">
                No recent reviews from brew buddies. They are still brewing up something to say.
            </div>
        {{else}}
            <div class="landing-modern-review-grid">
                {{#each review-data}}
                <article class="landing-modern-review-card">
                    <div class="landing-modern-review-top">
                        <div onclick="redirectToProfile('{{username}}')" class="landing-modern-review-user">
                            {{> redirectProfile}}
                        </div>

                        <div class="landing-modern-review-rating">
                            <span>{{rating}}</span>
                            <i class="fa fa-star"></i>
                        </div>
                    </div>

                    <div class="landing-modern-review-body">
                        <p class="landing-modern-review-label">Reviewing</p>
                        <a onclick="redirectToEstablishment('{{place_name}}')" class="landing-modern-review-place">
                            {{place_name}}
                        </a>

                        {{#if review_title}}
                        <h3 class="landing-modern-review-title">{{review_title}}</h3>
                        {{/if}}

                        <p class="landing-modern-review-caption">{{caption}}</p>
                    </div>
                </article>
                {{/each}}
            </div>
        {{/if}}
    </section>

    <section class="landing-modern-section">
        <div class="landing-modern-section-head">
            <div>
                <p class="landing-modern-section-eyebrow">Popular on Cofeed</p>
                <h2 class="landing-modern-section-title">Highly rated cafés</h2>
            </div>
            <a class="landing-modern-link" href="/viewEstablishments">See all establishments</a>
        </div>

        <div class="landing-modern-establishment-grid">
            {{#each establishment-data}}
            <article class="landing-modern-establishment-card">
                <img
                    class="landing-modern-establishment-image"
                    src="{{banner_image}}"
                    alt="{{establishment_name}}"
                    onerror="this.onerror=null;this.src='/images/establishment-fallback.png';"
                >

                <div class="landing-modern-establishment-body">
                    <div class="landing-modern-establishment-top">
                        <h3>{{establishment_name}}</h3>
                        <div class="landing-modern-establishment-rating">
                            <span>{{establishment_ratings}}</span>
                            <i class="fa fa-star"></i>
                        </div>
                    </div>

                    <p class="landing-modern-establishment-location">
                        <i class="fa fa-map-marker"></i> {{establishment_address}}
                    </p>

                    <p class="landing-modern-establishment-description">
                        {{establishment_description}}
                    </p>

                    <button class="landing-modern-establishment-button" onclick="redirectToEstablishment('{{establishment_name}}')">
                        See More
                    </button>
                </div>
            </article>
            {{/each}}
        </div>
    </section>
</div>

<!-- container for the footer -->
<div class="parent-footer">
    {{> footer}}
</div>