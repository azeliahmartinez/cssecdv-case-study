<div class="login-page-modern">
    <div class="login-shell-modern">
        <div class="login-card-modern">
            <div class="login-left-modern">
                <img class="login-logo-modern" src="/images/logo2.png" alt="CoFeed Logo"/>

                <div class="login-copy-modern">
                    <p class="login-eyebrow-modern">Welcome Back</p>
                    <h1 class="login-greeting-modern">Welcome back,<br>Brew Buddy!</h1>
                    <p class="login-tagline-modern">Ready to Sip, Share, and</p>
                    <p class="login-tagline-modern">Discover the Perfect Pour?</p>
                </div>
            </div>

            <div class="login-divider-modern"></div>

            <div class="login-right-modern">
                <p class="login-main-modern">Login</p>
                <p class="login-subtext-modern">Access your account to explore cafés, manage reviews, and continue your Cofeed experience.</p>

                <form name="read-user" onsubmit="return submitLoginForm()">
                    <div class="login-form-group-modern">
                        <label for="username-field">Username</label>
                        <input name="username" id="username-field" type="text" placeholder="Enter your username">
                    </div>

                    <div class="login-form-group-modern">
                        <label for="password-field">Password</label>
                        <div class="login-password-input-wrap-modern">
                            <input name="password" id="password-field" type="password" placeholder="Enter your password">
                            <i
                                id="toggle-password"
                                class="fa fa-eye-slash login-password-toggle-modern"
                                onclick="togglePasswordVisibility('password-field', 'toggle-password')"
                            ></i>
                        </div>
                    </div>

                    <div class="login-remember-row-modern">
                        <label class="login-remember-label-modern">
                            <input type="checkbox" id="remember-me" name="remember-me">
                            <span>Remember Me</span>
                        </label>
                    </div>

                    <input type="submit" class="login-button-modern" value="Login">
                </form>

                <p class="login-link-modern"><a href="/forgotpassword">Forgot Password?</a></p>
                <p class="login-link-modern"><a href="/registration">Don't have an account yet? Create an account</a></p>
            </div>
        </div>
    </div>
</div>